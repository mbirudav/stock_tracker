# Required: Get your key at https://openrouter.ai
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Polygon.io API key for real market data
# Leave blank to use the built-in market simulator (recommended)
MASSIVE_API_KEY=

# Set to "true" to use deterministic mock LLM responses (for testing/development)
LLM_MOCK=false
